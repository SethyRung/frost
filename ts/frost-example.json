{
  "$schema": "./schemas/config.json",
  "projects": {
    "portfolio": {
      "root": "../portfolio",
      "apps": {
        "frontend": {
          "command": "pnpm dev"
        }
      }
    },
    "chongkran": {
      "root": "../Chongkran",
      "apps": {
        "chongkran-frontend": {
          "cwd": "chongkran-frontend",
          "command": "pnpm dev"
        },
        "chongkran-backend": {
          "cwd": "chongkran-backend",
          "command": "pnpm start:dev"
        }
      }
    },
    "web bridge": {
      "root": "../WebBridge",
      "apps": {
        "glitch": {
          "command": "pnpm dev",
          "cwd": "/glitch"
        }
      }
    }
  }
}
